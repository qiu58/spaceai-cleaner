{
  "name": "spaceai-cleaner",
  "version": "1.0.0",
  "description": "SpaceAI 智能磁盘分析清理工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.spaceai.cleaner",
    "productName": "SpaceAI",
    "copyright": "Copyright © 2026 SpaceAI",
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "dist/python/spaceai-backend.exe",
        "to": "spaceai-backend.exe"
      }
    ]
  },
  "keywords": [
    "disk",
    "cleaner",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^11.5.0",
    "electron-builder": "^22.14.13",
    "electron-packager": "^15.4.0"
  },
  "dependencies": {
    "d3": "^6.7.0",
    "node-schedule": "^1.3.2"
  }
}
